# Add this section to .claude/kb/_index.yaml under 'domains:'

{{DOMAIN_KEY}}:
  name: {{DOMAIN_DISPLAY_NAME}}
  description: {{DOMAIN_DESCRIPTION}}
  path: {{DOMAIN_KEY}}/
  status: draft           # lifecycle: draft -> in_progress -> complete
  last_updated: {{DATE}}  # YYYY-MM-DD; kb-architect bumps this on /update-kb
  agents: [{{AGENT_NAME}}]
  entry_points:
    index: index.md
    quick_reference: quick-reference.md
  concepts:
    - name: {{CONCEPT_1}}
      path: concepts/{{CONCEPT_1}}.md
      confidence: 0.95
  patterns:
    - name: {{PATTERN_1}}
      path: patterns/{{PATTERN_1}}.md
