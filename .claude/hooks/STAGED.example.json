{
  "_comment": "Staged hooks — not yet wired. Enable once Makefile targets (make format, make test) are exercised and the gate workflow is confirmed. To enable: copy the relevant block(s) below into the `hooks` object in .claude/settings.json.",
  "PreToolUse": [
    {
      "matcher": "Bash",
      "hooks": [
        {
          "type": "command",
          "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/commit-gate.sh"
        }
      ]
    }
  ],
  "PostToolUse": [
    {
      "matcher": "Bash",
      "hooks": [
        {
          "type": "command",
          "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/gate-track.sh"
        }
      ]
    }
  ],
  "PostCompact": [
    {
      "matcher": "",
      "hooks": [
        {
          "type": "command",
          "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/post-compact-log.sh"
        }
      ]
    }
  ]
}
